# ===========================================
# 복붙: 루트에 .env 로 저장 후 값만 채우기
#   PowerShell: Copy-Item .env.template .env
# ===========================================

# --- Vite 프론트 (npm run dev / build) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 관리자 콘솔 허용 이메일(쉼표 구분, 소문자로 비교)
# VITE_ADMIN_EMAILS=veroro@eternalsix.com

# 카카오 JavaScript 키 (카카오 개발자 → 내 애플리케이션 → 앱 키 → JavaScript 키)
# 플랫폼에 웹 도메인(로컬은 http://localhost:5173 등) 등록 후 사용
VITE_KAKAO_JAVASCRIPT_KEY=

# --- Supabase Edge Functions (로컬: npx supabase functions serve --env-file .env) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Edge CORS (선택, 쉼표로 여러 도메인)
# CORS_ALLOWED_ORIGINS=https://your-app.netlify.app

# --- 배포 시 ---
# Supabase: Edge Functions → Secrets 에 위 키 이름으로 등록
# Netlify 프론트: VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_KAKAO_JAVASCRIPT_KEY(선택), VITE_ADMIN_EMAILS(선택)
