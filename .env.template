# ===========================================
# 복붙: 루트에 .env 로 저장 후 값만 채우기
#   PowerShell: Copy-Item .env.template .env
# ===========================================

# --- Vite 프론트 (npm run dev / build) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_TOSS_WIDGET_CLIENT_KEY=your-toss-widget-client-key

# --- Supabase Edge Functions (로컬: npx supabase functions serve --env-file .env) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
TOSS_SECRET_KEY=your-toss-secret-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- 배포 시 ---
# Supabase: Edge Functions → Secrets 에 위 키 이름으로 등록
# Netlify 프론트 배포: VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_TOSS_WIDGET_CLIENT_KEY 사용
# Netlify 서버 함수: TOSS_SECRET_KEY 사용 (이 저장소의 netlify/functions 는 SUPABASE_URL을 사용하지 않음)
# 만약 Netlify 프로젝트에 SUPABASE_URL을 별도로 등록했다면, 공개용 VITE_SUPABASE_URL과 값이 같아
# secret scan 오탐지가 날 수 있으므로 저장소의 netlify.toml 예외 설정을 유지하세요.
