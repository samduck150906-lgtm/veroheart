# 랜딩(landing/) 빌드 환경변수
# 복붙: landing/.env.local 로 저장 후 값만 채우기 (Netlify 배포 시에는 사이트 환경변수로 등록)

# 메인 앱(src/)과 동일한 Supabase 프로젝트 값 사용
# anon key만 사용하며, service_role 키는 절대 이 파일/랜딩 코드에 넣지 않는다.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 선택 — 없으면 기본값(COMPANY.email) 사용
# NEXT_PUBLIC_CONTACT_EMAIL=veroro@eternalsix.com
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=
# NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=

# --- Supabase 쪽 설정 (Edge Function Secrets, landing과 별개) ---
# supabase/functions/waitlist-signup 이 사용하는 값 — Supabase 대시보드의
# Edge Functions → Secrets 에 등록 (SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY는
# Supabase가 기본 제공하는 경우가 많음)
